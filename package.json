{
    "name": "16-words",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "eslint .",
        "deploy": "npm build && npx gh-pages -d build -t true",
        "postbuild": "node scripts/postbuild.js"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@iconify-svelte/material-symbols-light": "^1.0.43",
        "@inlang/paraglide-js": "^2.18.2",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/enhanced-img": "^0.11.0",
        "@sveltejs/kit": "^2.63.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^24",
        "eslint": "^10.4.1",
        "eslint-plugin-svelte": "^3.19.0",
        "gh-pages": "^6.3.0",
        "globals": "^17.6.0",
        "svelte": "^5.56.1",
        "svelte-check": "^4.6.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vite": "^8.0.16"
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "@inlang/paraglide-js-svelte": "^1.0.3",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.8",
        "uuid": "^14.0.1"
    },
    "allowScripts": {
        "sharp@0.34.5": true
    }
}
